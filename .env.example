# ── Supabase (service-role key, HANYA di server) ──
SUPABASE_URL=https://lzyibxgxrdhwpolrolvt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Firebase Cloud Messaging (service account) ──
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# PEM dengan newline di-escape sebagai \n
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Sesi admin (rahasia acak panjang) ──
ADMIN_SESSION_SECRET=ganti-dengan-string-acak-panjang

# ── Cron (untuk scheduler eksternal / worker) ──
CRON_SECRET=ganti-dengan-string-acak-panjang

# ── Opsional ──
APP_TIMEZONE=Asia/Jakarta
WINBACK_TIME=19:00
ADZAN_ANDROID_CHANNEL_ID=adzan_channel
ADZAN_ANDROID_SOUND=adzan
ADZAN_APNS_SOUND=adzan.caf
# Untuk scripts/cron-worker.mjs
CRON_BASE_URL=http://localhost:3000
CRON_INTERVAL_SECONDS=60
CRON_RUN_ON_START=false
